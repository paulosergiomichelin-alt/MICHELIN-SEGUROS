rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // 0. SAFETY NET — default deny everything
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================
    // HELPERS
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Reads the caller's user document once; Firestore caches it
    // within the same evaluation so this is called at most once.
    function callerDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function callerExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // SUPERADMIN — full platform bypass, set manually in Firebase Console:
    //   users/{uid}  →  superadmin: true
    // Never settable by the app itself.
    function isSuperAdmin() {
      return isSignedIn() && callerExists() && callerDoc().get('superadmin', false) == true;
    }

    // ADMIN — role:'admin' OR canManageUsers permission inside the org
    function isAdmin() {
      return isSignedIn() && callerExists() && (
        callerDoc().role == 'admin' ||
        callerDoc().permissions.get('canManageUsers', false) == true
      );
    }

    // Organization isolation: document must belong to same org as caller,
    // OR caller is admin/superadmin.
    function getOrgId() {
      return request.auth.token.get('organizationId',
        callerExists() ? callerDoc().get('organizationId', null) : null
      );
    }

    function sameOrg(data) {
      let docOrg  = data.get('organizationId', null);
      let userOrg = getOrgId();
      return isSuperAdmin() || (userOrg != null && docOrg == userOrg);
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isImmutable(field) {
      return !(field in incoming()) ||
             (!(field in existing()) && (isAdmin() || isSuperAdmin())) ||
             (field in existing() && incoming()[field] == existing()[field]);
    }

    // Prevents regular users from escalating their own role/permissions.
    // Superadmin field is ALWAYS immutable via the app (set only in console).
    function isAllowedUserUpdate(userId) {
      return (isVerified() && isOwner(userId)) &&
             isImmutable('role') &&
             isImmutable('permissions') &&
             isImmutable('superadmin') &&
             isImmutable('email') &&
             (isImmutable('organizationId') || (
               !('organizationId' in existing()) &&
               incoming().get('organizationId', '') == 'default'
             )) &&
             (isImmutable('userType') || (
               !('userType' in existing()) &&
               incoming().get('userType', '') == 'HUMAN'
             )) &&
             (isImmutable('status') || (
               !('status' in existing()) &&
               incoming().get('status', '') == 'active'
             ));
    }

    // =========================================================
    // VALIDATION BLUEPRINTS
    // =========================================================

    function isValidLead(data) {
      return data.keys().hasAll(['id', 'organizationId', 'status']) &&
             data.id is string &&
             data.organizationId is string &&
             data.status is string &&
             (!('name' in data) || (data.name is string && data.name.size() <= 255));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'leadId', 'organizationId', 'sender']) &&
             data.id is string &&
             data.leadId is string &&
             data.organizationId is string &&
             data.sender is string;
    }

    // =========================================================
    // 1. LEADS
    // =========================================================
    match /leads/{leadId} {
      allow read: if isSignedIn() && sameOrg(existing());

      allow create: if isVerified() &&
                    isValidId(leadId) &&
                    isValidLead(incoming()) &&
                    sameOrg(incoming());

      allow update: if isVerified() &&
                    sameOrg(existing()) &&
                    sameOrg(incoming()) &&
                    isImmutable('organizationId') && (
                      isSuperAdmin() ||
                      isAdmin() || (
                        existing().ownerId == request.auth.uid &&
                        isImmutable('ownerId')
                      )
                    );

      allow delete: if (isAdmin() || isSuperAdmin()) && sameOrg(existing());
    }

    // =========================================================
    // 2. MESSAGES
    // =========================================================
    match /messages/{msgId} {
      allow read: if isSignedIn() && sameOrg(existing());

      allow create: if isVerified() &&
                    isValidId(msgId) &&
                    isValidMessage(incoming()) &&
                    sameOrg(incoming());

      allow update, delete: if (isAdmin() || isSuperAdmin()) && sameOrg(existing());
    }

    // =========================================================
    // 3. USERS
    // =========================================================
    match /users/{userId} {
      allow get:  if isSignedIn() && (isSuperAdmin() || isOwner(userId) || sameOrg(existing()));
      allow list: if isSignedIn() && (isSuperAdmin() || sameOrg(existing()));

      // isOwner: user creates own doc (self-registration)
      // isAdmin/isSuperAdmin: admin creates user doc during empresa onboarding
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin() || isSuperAdmin());

      allow update: if isSuperAdmin() ||
                    isAllowedUserUpdate(userId) ||
                    (isAdmin() && sameOrg(existing()));

      allow delete: if (isAdmin() || isSuperAdmin()) && sameOrg(existing());
    }

    // =========================================================
    // 4. NOTIFICATIONS
    //    Access by ownership (userId field), not by org.
    //    Admins and superadmins see all.
    // =========================================================
    match /notifications/{id} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isAdmin() ||
        resource.data.get('userId', '') == request.auth.uid
      );

      allow create: if isVerified() && (
        isSuperAdmin() ||
        sameOrg(incoming()) ||
        incoming().get('userId', '') == request.auth.uid
      );

      allow delete: if isAdmin() || isSuperAdmin();
    }

    // =========================================================
    // 5. INFRASTRUCTURE
    // =========================================================
    match /processing_locks/{lockId} {
      allow read, write: if isSignedIn();
    }

    match /dead_letter_queue/{id} {
      allow read:   if isAdmin() || isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /follow_up/{id} {
      allow read:  if isSignedIn() && (isSuperAdmin() || sameOrg(existing()));
      allow write: if isVerified() && (isSuperAdmin() || sameOrg(incoming()));
    }

    match /audit_logs/{id} {
      allow read:   if isAdmin() || isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /system_logs/{id} {
      allow read:   if isAdmin() || isSuperAdmin();
      allow create: if isSignedIn();
    }

    match /system_metrics/{id} {
      allow read:   if isAdmin() || isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isSuperAdmin();
    }

    // =========================================================
    // 6. CONFIGURAÇÕES GLOBAIS
    // =========================================================
    match /settings/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /config/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /access_profiles/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // =========================================================
    // 7. FLOWS / AUTOMAÇÃO
    // =========================================================
    match /flows/{flowId} {
      allow read:  if isSignedIn() && (isSuperAdmin() || sameOrg(existing()));
      allow write: if (isAdmin() || isSuperAdmin()) && (isSuperAdmin() || sameOrg(incoming()));
    }

    // =========================================================
    // 8. EMPRESAS (Multi-tenant management)
    // =========================================================
    match /empresas/{empresaId} {
      // Onboarding: user cria a própria empresa, ou admin cria para outro usuário
      allow create: if isSignedIn() && (
        isSuperAdmin() ||
        isAdmin() ||
        (incoming().ownerUserId == request.auth.uid &&
         incoming().organizationId == empresaId)
      );

      // get (documento único): superadmin ou membro da org
      allow get: if isSignedIn() && (
        isSuperAdmin() ||
        (callerExists() && callerDoc().get('organizationId', '') == empresaId)
      );
      // list (coleção): somente superadmin
      allow list: if isSuperAdmin();

      allow update: if isSuperAdmin();

      allow delete: if isSuperAdmin();
    }
  }
}
