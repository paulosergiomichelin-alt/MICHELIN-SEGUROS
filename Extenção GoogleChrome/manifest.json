{
  "manifest_version": 3,
  "name": "Michelin Seguros - Automação",
  "version": "2.0.0",
  "description": "Extensão integrada ao sistema Michelin Seguros para abertura de sites, login e preenchimento automatizado de formulários.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://localhost:*/*",
      "https://localhost/*",
      "https://localhost:*/*",
      "https://gen-lang-client-0929974546.web.app/*",
      "https://gen-lang-client-0929974546.firebaseapp.com/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://aggilizador.com.br/*",
        "https://*.aggilizador.com.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
