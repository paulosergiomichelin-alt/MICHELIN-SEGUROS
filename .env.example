# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Required for other models (Claude, etc) - MUST HAVE VITE_ PREFIX FOR FRONTEND ACCESS
VITE_OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# META_ACCESS_TOKEN: Required for WhatsApp/Meta integration
META_ACCESS_TOKEN="YOUR_META_ACCESS_TOKEN"

# WHATSAPP_PHONE_NUMBER_ID: Required for WhatsApp integration
WHATSAPP_PHONE_NUMBER_ID="YOUR_WHATSAPP_PHONE_NUMBER_ID"

# FIRESTORE_ECO_MODE: Set to true to reduce Firestore reads/writes (longer cache, less realtime)
VITE_FIRESTORE_ECO_MODE=false

# ─── DATADOG (server-side — never expose in VITE_ vars) ─────────────────────
# Used by server.ts to proxy LLM Observability spans and by GitHub Actions
DD_API_KEY=YOUR_DD_API_KEY
DD_SITE=us5.datadoghq.com

# ─── DATADOG RUM + LOGS ───────────────────────────────────────────────────────
# Enable/disable Datadog observability (set true in .env.production only)
VITE_DD_ENABLED=false

# Datadog site: us5.datadoghq.com | datadoghq.com | eu1.datadoghq.com
VITE_DD_SITE=us5.datadoghq.com

# RUM Application ID and Client Token
# Datadog → UX Monitoring → RUM Applications → Create Application (React) → copy values
VITE_DD_RUM_APP_ID=YOUR_RUM_APP_ID
VITE_DD_RUM_CLIENT_TOKEN=YOUR_RUM_CLIENT_TOKEN

VITE_DD_SERVICE=michelin-crm-frontend
VITE_DD_ENV=production
# VITE_DD_VERSION is injected by CI (github.sha) — set manually for local testing
VITE_DD_VERSION=local
