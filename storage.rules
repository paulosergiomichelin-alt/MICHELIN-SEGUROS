rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // =========================================================
    // 1. ORG-SCOPED USER FILES  (branding, documents, avatars)
    //    Path: orgs/{organizationId}/users/{userId}/...
    //
    //    NOTE: Storage Security Rules cannot query named Firestore
    //    databases (only the default). Since this project uses a
    //    named DB, we cannot verify org membership here. Instead we
    //    rely on the userId segment matching the authenticated UID —
    //    which is already a strong ownership guarantee.
    // =========================================================
    match /orgs/{organizationId}/users/{userId}/{allPaths=**} {
      // Only the file owner can write
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Any signed-in user can read (admins need cross-user access)
      allow read: if isSignedIn();
    }

    // =========================================================
    // 2. COMPANY LOGOS  (empresaId == organizationId)
    //    Path: empresas/{empresaId}/...
    // =========================================================
    match /empresas/{empresaId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // =========================================================
    // 3. HEALTH CHECK  (used by SystemHealth screen)
    //    Path: health_check/{uid}/...
    // =========================================================
    match /health_check/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // =========================================================
    // 4. LEGACY USER FILES (superadmin / pre-org paths)
    //    Path: users/{userId}/...
    // =========================================================
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // =========================================================
    // SAFETY NET — deny everything else
    // =========================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
